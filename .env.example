# Copy to .env.local (gitignored) and fill in.
#
# YouTube Data API v3 key, used by the Talks section to list the playlist's
# videos in the browser. This key ships in the built bundle, so it is NOT
# secret — protect it instead by restricting it in the Google Cloud console:
#   - Application restriction: HTTP referrers -> your site's domain(s)
#   - API restriction: YouTube Data API v3 only
# It is free and quota-capped; worst case on leak is quota exhaustion.
VITE_YOUTUBE_API_KEY=

# Optional: override the talks playlist. Defaults to the one in Talks.tsx.
VITE_TALKS_PLAYLIST_ID=
